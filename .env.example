# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0

# PostgreSQL
POSTGRES_DB=daily_trivia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-your-postgres-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# Production alternative: Neon connection string, including sslmode=require
DATABASE_URL=

# Authentication and email
PLATFORM_ADMIN_EMAILS=himanshu.kumar@ssc-spc.gc.ca
ALLOWED_EMAIL_DOMAINS=ssc-spc.gc.ca
LOGIN_CODE_EXPIRY_MINUTES=10
EMAIL_DELIVERY_PROVIDER=smtp
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@daily-trivia.local
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10

# Production email alternative: Brevo HTTPS API
BREVO_API_KEY=
BREVO_SENDER_EMAIL=dailytrivia.manager@gmail.com
BREVO_SENDER_NAME=Daily Trivia

# Groq AI trivia generation and answer-window configuration
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
TRIVIA_ANSWER_WINDOW_HOURS=24
TRIVIA_QUESTION_RETENTION_DAYS=17
